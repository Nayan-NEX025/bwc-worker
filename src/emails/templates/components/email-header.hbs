{{! emails/templates/components/email-header.hbs }}
<table
  width="100%"
  cellpadding="0"
  cellspacing="0"
  border="0"
  style="border-collapse: collapse;"
>
  <tr>
    <td style="padding-bottom: 30px; text-align: center;">
      {{#if logoUrl}}
        <img
          src="{{logoUrl}}"
          alt="{{appName}}"
          style="max-width: 150px; height: auto; margin-bottom: 20px;"
        />
      {{/if}}
      <h1 style="margin: 0; font-size: 24px; color: #333;">
        {{title}}
      </h1>
      {{#if subtitle}}
        <p style="margin: 10px 0 0 0; font-size: 16px; color: #6c757d;">
          {{subtitle}}
        </p>
      {{/if}}
    </td>
  </tr>
</table>