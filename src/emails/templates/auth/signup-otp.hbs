{{#> base}}

  {{> components/email-header title="Verify your email"}}

  <div style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #333333; line-height: 1.6;">
    
    <p style="margin-top: 0;">Hello <strong>{{name}}</strong>,</p>

    <p>
      Welcome to <strong>{{appName}}</strong>!  
      Please use the One-Time Password (OTP) below to verify your email address and complete your signup.
    </p>

    <table width="100%" border="0" cellspacing="0" cellpadding="0" style="margin: 24px 0;">
      <tr>
        <td align="center">
          <div style="background-color: #f4f6f8; border: 1px solid #e1e4e8; border-radius: 6px; padding: 24px; text-align: center; max-width: 300px;">
            <span
              style="
                display: block;
                font-size: 12px;
                color: #666;
                text-transform: uppercase;
                letter-spacing: 1px;
                margin-bottom: 8px;
              "
            >
              Your Signup OTP
            </span>

            <span
              style="
                font-family: monospace;
                font-size: 32px;
                font-weight: bold;
                letter-spacing: 6px;
                color: #2c3e50;
                display: block;
              "
            >
              {{otp}}
            </span>
          </div>
        </td>
      </tr>
    </table>

    <p style="text-align: center; color: #666; font-size: 14px;">
      This code will expire in <strong>{{expiresIn}}</strong>.
    </p>

    <hr style="border: none; border-top: 1px solid #eee; margin: 30px 0;">

    <div style="font-size: 13px; color: #666;">
      <p style="margin-bottom: 10px;">
        <strong>Security Notice:</strong>  
        Do not share this code with anyone, including {{appName}} support staff.
      </p>
      <p style="margin-bottom: 0;">
        If you did not attempt to sign up, you can safely ignore this email.
      </p>
    </div>

  </div>

  {{> components/notice text="This is a secure automated message. Please do not reply."}}

{{/base}}
